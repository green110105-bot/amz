# 真接控制：set VITE_USE_REAL=true 后所有 provider 走真实后端
VITE_USE_REAL=false

# API 地址（默认走 vite proxy → http://localhost:8080）
VITE_API_BASE=

# === 后端 provider 接入说明 ===
# 1. LLM      — 在 apps/api 的环境配置中加 ANTHROPIC_API_KEY 或 OPENAI_API_KEY
# 2. SP-API   — Amazon Seller Central → Develop Apps → 申请 LWA refresh_token
# 3. Ads API  — Amazon Advertising → Apply → 拿 advertising-api refresh_token
# 4. 图像生成 — Imagen 3 / DALL-E 3 / Stable Diffusion + LoRA 三选一
# 5. 邮件     — SMTP / 阿里云邮件推送 / SendGrid
# 6. 微信     — 微信 Service / 企业微信 webhook
# 7. 数据库   — PostgreSQL（替代 LocalStorage）
