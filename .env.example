# Runtime mode defaults: deterministic mocks, no real store writes.
NODE_ENV=development
APP_ENV=local
MOCK_MODE=true
DATA_PROVIDER_MODE=mock
# Canonical real-write switch is ADS_REAL_WRITES_ENABLED (read by the live-write gate,
# security headers, and /ready). REAL_WRITES_ENABLED is a legacy alias kept for
# backwards compatibility — prefer ADS_REAL_WRITES_ENABLED. (X-P2-01)
REAL_WRITES_ENABLED=false
AUDIT_REQUIRED=true
SANDBOX_ONLY=true
ALLOW_PRODUCTION_DEPLOY=false
REQUIRE_DEPLOY_APPROVAL=true
REQUIRE_BACKUP_BEFORE_DEPLOY=true
SECRET_SOURCE=local-placeholder

# API/Web service ports and URLs.
API_PORT=8080
WEB_PORT=3000
SERVICES_PORT=8090
API_BASE_URL=http://localhost:8080
WEB_BASE_URL=http://localhost:3000
SERVICES_BASE_URL=http://localhost:8090

# Local datastore defaults. Replace only in sandbox/prod secret stores.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=amz_operator
POSTGRES_USER=amz_app
POSTGRES_PASSWORD=change-me-local-only
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=amz_events
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=change-me-local-only

# External providers stay blocked unless credentials, contracts, and approvals exist.
# AES-256-GCM key for at-rest encryption of refresh / access tokens. 32 bytes hex.
# Generate with: openssl rand -hex 32
CREDENTIAL_ENC_KEY=
# SP-API (LWA). client_id / client_secret are APP-LEVEL (one developer app).
# Per-seller refresh_token is stored encrypted in store_credentials per (user, store).
SPAPI_PROVIDER=blocked
SPAPI_LWA_CLIENT_ID=
SPAPI_LWA_CLIENT_SECRET=
SPAPI_DEFAULT_REGION=NA
SPAPI_USE_SANDBOX=true
# SP-API one-click OAuth. Register both Login URI and Redirect URI in Seller Central.
# Defaults are inferred from the public API origin when blank.
SPAPI_OAUTH_APPLICATION_ID=
SPAPI_OAUTH_LOGIN_URI=
SPAPI_OAUTH_REDIRECT_URI=
SPAPI_OAUTH_SELLER_CENTRAL_URL=
SPAPI_OAUTH_AUTHORIZE_URL=
SPAPI_OAUTH_VERSION=
# Legacy single-tenant fields (deprecated; do not use for multi-tenant).
SPAPI_CLIENT_ID=
SPAPI_CLIENT_SECRET=
SPAPI_REFRESH_TOKEN=
ADS_PROVIDER=blocked
# Amazon Ads API (LWA). ADS_LWA_* is preferred; ADS_CLIENT_* remains accepted as a legacy alias.
ADS_LWA_CLIENT_ID=
ADS_LWA_CLIENT_SECRET=
# Amazon Ads / Login with Amazon one-click OAuth.
# Redirect URI must be registered in the LWA security profile / Ads app.
ADS_OAUTH_REDIRECT_URI=
ADS_OAUTH_AUTHORIZE_URL=https://www.amazon.com/ap/oa
ADS_OAUTH_SCOPE=advertising::campaign_management
ADS_API_MOCK=true
ADS_API_USE_SANDBOX=true
ADS_API_DEFAULT_REGION=NA
ADS_REAL_WRITES_ENABLED=false
ADS_REAL_WRITES_STORE_ALLOWLIST=
ADS_REAL_WRITES_PROFILE_ALLOWLIST=
ADS_REAL_WRITES_ALLOWED_PRIMITIVES=ADJUST_BID
ADS_REAL_WRITE_MAX_BID_CHANGE_PCT=0.10
ADS_REAL_WRITE_MAX_BUDGET_CHANGE_PCT=0.05
ADS_CLIENT_ID=
ADS_CLIENT_SECRET=
ADS_REFRESH_TOKEN=
ADS_PROFILE_ID=
# Public web origin used after OAuth callbacks, e.g. http://47.97.252.71 or https://app.example.com.
AMZ_WEB_BASE_URL=
KEEPA_PROVIDER=blocked
KEEPA_API_KEY=
SELLERSPRITE_PROVIDER=blocked
SELLERSPRITE_API_KEY=
HELIUM10_PROVIDER=blocked
HELIUM10_API_KEY=
LLM_PROVIDER=mock
LLM_API_KEY=
EMAIL_PROVIDER=mock
EMAIL_PROVIDER_KEY=
WECOM_WEBHOOK=
PAYMENT_PROVIDER=mock
PAYMENT_API_KEY=

# --- Production security hardening (deep-rebuild 2026-06) ---
# Override the demo account password (defaults to 'demo' for local dev only).
DEMO_PASSWORD=
# Set to 'true' in production to skip seeding the public demo/demo account entirely.
DISABLE_DEMO_USER=
